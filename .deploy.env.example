# Copy to .deploy.env (gitignored) and fill in threlmark.com's all-inkl FTP login.
# Used by `npm run deploy:marketing` to publish site/** to threlmark.com.
#
# Find these in the all-inkl KAS panel under FTP, for the threlmark.com account.
# all-inkl creates a separate, chrooted FTP user per domain — use threlmark.com's
# own credentials here (another domain's login will not reach threlmark.com).
FTP_HOST=wXXXXXXX.kasserver.com
FTP_USER=fXXXXXXX
FTP_PASS='your-ftp-password'
# Remote directory the FTP user should write to (often "/" or "/threlmark.com/").
FTP_PATH=/
